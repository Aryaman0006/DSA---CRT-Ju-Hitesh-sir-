#include <iostream>
using namespace std;

// Selection sort//

int main()
{
    int arr[5]={5,4,3,2,1};
    int n=5;
    
    for( int i=0; i<=n-1; i++)
    {
        //ASSUME//
        int min_element_index =i;
        
        for ( int j=i+1; j<=n-1; j++)
        {
            if ( arr[j]< arr[min_element_index])
            {
                min_element_index=j;
                
            }
        }
        swap (arr[i],arr[min_element_index]);
        
    }
    
    
// display sorted array
 for (int i = 0; i < n; i++)
    {
        cout << arr[i] << " ";
    }
}
