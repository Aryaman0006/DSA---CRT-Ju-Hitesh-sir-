#include <iostream>
#include <vector>
using namespace std;

class Stack
{
    vector<int> arr;

public:

    void push(int v)
    {
        arr.push_back(v);
    }

    void pop()
    {
        if (!arr.empty())
        {
            arr.pop_back();
        }
    }

    bool empty()
    {
        return arr.size() == 0;
    }

    int top()
    {
        return arr[arr.size() - 1];
    }
};

int main()
{
    Stack st;

    st.push(1);
    st.push(2);
    st.push(3);

    while (!st.empty())
    {
        cout << st.top() << " ";
        st.pop();
    }

    return 0;
}
