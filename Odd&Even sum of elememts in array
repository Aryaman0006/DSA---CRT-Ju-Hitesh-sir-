#include <iostream>
using namespace std;

int main() 
{
    int arr[5] = {2,3,1,0,6};

    int oddsum = 0;
    int evensum = 0;

    for(int i = 0; i <= 4; i++)
    {
        if(arr[i] % 2 == 0)
        {
            evensum = evensum + arr[i];
        }
        else
        {
            oddsum = oddsum + arr[i];
        }
    }

    cout << "Sum of even elements = " << evensum << endl;
    cout << "Sum of odd elements = " << oddsum;
}
